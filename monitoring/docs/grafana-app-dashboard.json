{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "12.3.1" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "iteration": 0,
  "links": [],
  "panels": [
    {
      "type": "timeseries",
      "title": "Request rate (req/s) by endpoint",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum by (endpoint) (rate(http_requests_total[5m]))",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Error rate (5xx req/s)",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m]))",
          "legendFormat": "5xx"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "p95 request duration (seconds)",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "type": "heatmap",
      "title": "Request duration heatmap",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum by (le) (rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "{{le}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    },
    {
      "type": "timeseries",
      "title": "Active requests (in progress)",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(http_requests_in_progress)",
          "legendFormat": "in_progress"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
    },
    {
      "type": "piechart",
      "title": "Status code distribution (req/s)",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum by (status_code) (rate(http_requests_total[5m]))",
          "legendFormat": "{{status_code}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
    },
    {
      "type": "stat",
      "title": "App up (job=app)",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "up{job=\"app\"}",
          "legendFormat": "up"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 24 }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["lab08", "prometheus", "metrics"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "DevOps Info Service — Metrics (Lab 8)",
  "uid": "lab08-devops-metrics",
  "version": 1
}

